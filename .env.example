# =============================================================================
# MyClup Environment Variables
# =============================================================================
# Copy this file to .env or .env.local and fill in values.
# Never commit .env, .env.local, or .env.*.local — they are gitignored.
#
# Categories:
#   1. App public — Safe to expose in client bundles (NEXT_PUBLIC_*, EXPO_PUBLIC_*)
#   2. Shared runtime — Non-secret, used by server or at build time
#   3. Secret server-only — NEVER expose to clients; server/BFF only
# =============================================================================

# -----------------------------------------------------------------------------
# 1. APP PUBLIC (exposed to client bundles)
# -----------------------------------------------------------------------------
# These may be embedded in web/mobile app builds. No secrets here.

# Supabase (public) — Project URL exposed to clients for Supabase client SDK
NEXT_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_URL=

# Supabase (public) — Anonymous key for client-side auth; use RLS for tenant safety
NEXT_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Public API base URL — Used by mobile apps to reach Next.js BFF
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Google Analytics 4 — Measurement ID (public, for website and web products)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# -----------------------------------------------------------------------------
# 2. SHARED RUNTIME (non-secret, server or build-time)
# -----------------------------------------------------------------------------
# Not exposed to client by default. Used by Next.js server, BFF, or build scripts.

# Node environment: development | test | production
NODE_ENV=development

# Public site URL — Used for canonical URLs, OG tags, sitemaps
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# LOCALIZATION
# See docs/07-technical-plan.md §11.2, §12.1
# -----------------------------------------------------------------------------
# Default locale when none is specified (e.g. en, tr)
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Comma-separated list of supported locales (e.g. en,tr,de)
NEXT_PUBLIC_SUPPORTED_LOCALES=en,tr

# Fallback locale when a translation is missing
NEXT_PUBLIC_FALLBACK_LOCALE=en

# Website locale URL strategy: path | domain | subdomain
#   path:     /en/about, /tr/hakkimizda
#   domain:   en.example.com, tr.example.com
#   subdomain: en.myclup.com, tr.myclup.com
NEXT_PUBLIC_LOCALE_URL_STRATEGY=path

# -----------------------------------------------------------------------------
# 3. SECRET SERVER-ONLY (NEVER expose to clients)
# -----------------------------------------------------------------------------
# These must only be used in server code (API routes, getServerSideProps,
# server actions, BFF). Never prefix with NEXT_PUBLIC_ or EXPO_PUBLIC_.
# AGENT.md: "Secrets never in client"

# Supabase service role key — Bypasses RLS; server-only; never in client
SUPABASE_SERVICE_ROLE_KEY=

# OAuth provider configuration — Configure in Supabase Dashboard → Authentication → Providers
# Client IDs may be public (used by client to initiate OAuth); secrets are server-only
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Ollama — AI service (server-side only; no client may call Ollama directly)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:0.5b-instruct
OLLAMA_TIMEOUT_MS=10000
AI_FEATURE_FLAG=enabled

# Webhook signing secrets (payment, auth, provider callbacks)
WEBHOOK_STRIPE_SECRET=
WEBHOOK_SUPABASE_SECRET=

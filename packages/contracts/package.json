{
  "name": "@myclup/contracts",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./health": {
      "types": "./dist/health/index.d.ts",
      "default": "./dist/health/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/auth/index.js"
    },
    "./common": {
      "types": "./dist/common/index.d.ts",
      "default": "./dist/common/index.js"
    },
    "./chat": {
      "types": "./dist/chat/index.d.ts",
      "default": "./dist/chat/index.js"
    },
    "./membership": {
      "types": "./dist/membership/index.d.ts",
      "default": "./dist/membership/index.js"
    },
    "./bookings": {
      "types": "./dist/bookings/index.d.ts",
      "default": "./dist/bookings/index.js"
    },
    "./billing": {
      "types": "./dist/billing/index.d.ts",
      "default": "./dist/billing/index.js"
    },
    "./addons": {
      "types": "./dist/addons/index.d.ts",
      "default": "./dist/addons/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "lint": "eslint . && prettier --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@myclup/types": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@myclup/config-eslint": "workspace:*",
    "@myclup/config-prettier": "workspace:*",
    "@myclup/config-typescript": "workspace:*",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
